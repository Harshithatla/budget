<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Splitwise — Personal Budget Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://accounts.google.com/gsi/client" async></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F7F6F3;
  --surface:#FFFFFF;
  --surface2:#F0EFE9;
  --border:#E2E0D8;
  --text:#1A1A18;
  --text2:#6B6A65;
  --text3:#9E9D98;
  --green:#0D7A5F;
  --green-bg:#E8F5F0;
  --amber:#9A5C0A;
  --amber-bg:#FEF3E2;
  --red:#B53030;
  --red-bg:#FDEAEA;
  --blue:#1A5FA0;
  --blue-bg:#EAF1FB;
  --purple:#5B46B8;
  --purple-bg:#EFEDFC;
  --radius:10px;
  --radius-sm:6px;
  --shadow:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6;min-height:100vh}
h1,h2,h3{font-weight:600;line-height:1.3}

/* Layout */
.shell{display:grid;grid-template-columns:220px 1fr;min-height:100vh;max-width:1100px;margin:0 auto}
@media(max-width:720px){.shell{grid-template-columns:1fr}}
.sidebar{background:var(--surface);border-right:1px solid var(--border);padding:1.5rem 1rem;display:flex;flex-direction:column;gap:4px;position:sticky;top:0;height:100vh;overflow-y:auto}
@media(max-width:720px){.sidebar{display:none}}
.main{padding:2rem 2rem 4rem;display:flex;flex-direction:column;gap:2rem}

/* Sidebar */
.logo{font-size:17px;font-weight:600;padding:.5rem .75rem;margin-bottom:.5rem;letter-spacing:-.3px}
.logo span{color:var(--green)}
.nav-btn{display:flex;align-items:center;gap:10px;padding:.6rem .75rem;border-radius:var(--radius-sm);border:none;background:transparent;cursor:pointer;font-size:14px;color:var(--text2);font-family:'Inter',sans-serif;width:100%;text-align:left;transition:background .12s,color .12s}
.nav-btn:hover{background:var(--surface2);color:var(--text)}
.nav-btn.active{background:var(--green-bg);color:var(--green);font-weight:500}
.nav-icon{width:18px;height:18px;flex-shrink:0}
.sidebar-footer{margin-top:auto;padding-top:1rem;border-top:1px solid var(--border)}
.month-label{font-size:12px;color:var(--text3);padding:.5rem .75rem}

/* Mobile nav */
.mobile-nav{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);padding:.5rem;z-index:100;gap:4px}
@media(max-width:720px){.mobile-nav{display:flex}}
.mob-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:.5rem;border:none;background:transparent;cursor:pointer;font-size:10px;color:var(--text3);font-family:'Inter',sans-serif;border-radius:var(--radius-sm);transition:color .12s}
.mob-btn.active{color:var(--green)}
.mob-btn svg{width:20px;height:20px}

/* Views */
.view{display:none}
.view.active{display:flex;flex-direction:column;gap:1.5rem}

/* Page header */
.page-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.page-title{font-size:20px;font-weight:600}
.month-switcher{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text2)}
.month-switcher button{border:1px solid var(--border);background:var(--surface);border-radius:var(--radius-sm);padding:4px 10px;cursor:pointer;font-size:13px;color:var(--text);transition:background .12s}
.month-switcher button:hover{background:var(--surface2)}
.month-display{font-weight:500;color:var(--text);min-width:80px;text-align:center}

/* Metric cards */
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.1rem 1.25rem;box-shadow:var(--shadow)}
.metric-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:.35rem;font-weight:500}
.metric-value{font-family:'DM Mono',monospace;font-size:24px;font-weight:500;letter-spacing:-.5px}
.metric-sub{font-size:12px;color:var(--text3);margin-top:4px}
.c-green{color:var(--green)}
.c-amber{color:var(--amber)}
.c-red{color:var(--red)}

/* Cards */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}
.card-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.card-title{font-size:14px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.5px}
.card-body{padding:0}

/* Expense list */
.expense-row{display:flex;align-items:center;gap:12px;padding:.85rem 1.25rem;border-bottom:1px solid var(--border);transition:background .1s}
.expense-row:last-child{border-bottom:none}
.expense-row:hover{background:var(--surface2)}
.cat-dot{width:36px;height:36px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:17px}
.exp-name{font-size:14px;font-weight:500;color:var(--text)}
.exp-meta{font-size:12px;color:var(--text3);margin-top:1px}
.exp-amount{font-family:'DM Mono',monospace;font-size:14px;font-weight:500;white-space:nowrap}
.exp-right{text-align:right;flex-shrink:0}
.exp-owed{font-size:11px;color:var(--green);margin-top:2px}
.pill{display:inline-block;font-size:10px;padding:2px 7px;border-radius:20px;font-weight:500;vertical-align:middle;margin-left:6px}
.pill-pending{background:var(--amber-bg);color:var(--amber)}
.pill-settled{background:var(--green-bg);color:var(--green)}
.exp-info{flex:1;min-width:0}
.empty-state{padding:3rem 1.25rem;text-align:center;color:var(--text3);font-size:14px}
.empty-state p{margin-top:.5rem;font-size:13px}

/* Add btn */
.add-row{display:flex;justify-content:flex-end;gap:8px}
.btn{display:inline-flex;align-items:center;gap:6px;padding:.55rem 1rem;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--surface);cursor:pointer;font-size:13px;font-family:'Inter',sans-serif;font-weight:500;color:var(--text);transition:background .12s,border-color .12s;white-space:nowrap}
.btn:hover{background:var(--surface2)}
.btn-primary{background:var(--text);color:var(--surface);border-color:var(--text)}
.btn-primary:hover{background:#333}
.btn-danger{background:var(--red-bg);color:var(--red);border-color:#F4C5C5}
.btn-danger:hover{background:#FDDADA}

/* Modal */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;align-items:center;justify-content:center;padding:1rem}
.overlay.open{display:flex}
.modal{background:var(--surface);border-radius:var(--radius);width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,.15);overflow:hidden}
.modal-header{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-size:16px;font-weight:600}
.modal-close{border:none;background:none;cursor:pointer;color:var(--text3);font-size:20px;padding:2px;line-height:1;transition:color .12s}
.modal-close:hover{color:var(--text)}
.modal-body{padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:14px}
.modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
.form-field{display:flex;flex-direction:column;gap:5px}
.form-field label{font-size:12px;font-weight:500;color:var(--text2)}
.form-field input,.form-field select,.form-field textarea{border:1px solid var(--border);border-radius:var(--radius-sm);padding:.55rem .75rem;font-size:14px;font-family:'Inter',sans-serif;background:var(--surface);color:var(--text);outline:none;transition:border-color .12s}
.form-field input:focus,.form-field select:focus,.form-field textarea:focus{border-color:var(--green)}
.form-row2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-hint{font-size:11px;color:var(--text3)}

/* Splits view */
.split-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:1.1rem 1.25rem}
.split-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem}
.split-person{display:flex;align-items:center;gap:10px}
.avatar{width:34px;height:34px;border-radius:50%;background:var(--purple-bg);color:var(--purple);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.split-name{font-size:15px;font-weight:600}
.split-amount{font-family:'DM Mono',monospace;font-size:18px;font-weight:500;color:var(--amber)}
.split-items{font-size:12px;color:var(--text3);margin-bottom:.75rem}
.splits-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px}
.no-splits{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:3rem;text-align:center;color:var(--text3)}

/* Budget bars */
.budget-row{margin-bottom:1.1rem}
.budget-meta{display:flex;justify-content:space-between;margin-bottom:5px;font-size:13px}
.budget-name{font-weight:500}
.budget-nums{font-family:'DM Mono',monospace;font-size:12px;color:var(--text2)}
.budget-track{height:8px;background:var(--surface2);border-radius:20px;overflow:hidden}
.budget-fill{height:100%;border-radius:20px;transition:width .4s}

/* Category chart */
.chart-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.chart-lbl{font-size:12px;color:var(--text2);width:110px;text-align:right;flex-shrink:0}
.chart-track{flex:1;height:22px;background:var(--surface2);border-radius:4px;overflow:hidden}
.chart-fill{height:100%;border-radius:4px;display:flex;align-items:center;padding-left:8px;transition:width .5s}
.chart-val{font-family:'DM Mono',monospace;font-size:11px;font-weight:500}

/* Settings */
.settings-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid var(--border);gap:1rem;flex-wrap:wrap}
.settings-row:last-child{border-bottom:none}
.settings-label{font-size:14px;font-weight:500}
.settings-desc{font-size:12px;color:var(--text3);margin-top:2px}
.settings-control input{border:1px solid var(--border);border-radius:var(--radius-sm);padding:.4rem .6rem;font-size:14px;font-family:'DM Mono',monospace;width:110px;text-align:right;background:var(--surface);color:var(--text);outline:none}
.settings-control input:focus{border-color:var(--green)}

/* Toast */
.toast{position:fixed;bottom:5rem;left:50%;transform:translateX(-50%);background:var(--text);color:var(--surface);padding:.6rem 1.2rem;border-radius:20px;font-size:13px;font-weight:500;opacity:0;transition:opacity .2s;pointer-events:none;z-index:300;white-space:nowrap}
.toast.show{opacity:1}

/* Month-over-month */
.mom-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:10px}
.mom-card{background:var(--surface2);border-radius:var(--radius-sm);padding:.75rem;text-align:center}
.mom-month{font-size:11px;color:var(--text3);margin-bottom:4px}
.mom-val{font-family:'DM Mono',monospace;font-size:15px;font-weight:500}
.mom-current{background:var(--green-bg)}
.mom-current .mom-val{color:var(--green)}

/* Friend chips */
.chip{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:20px;border:1.5px solid var(--border);background:var(--surface);font-size:13px;font-weight:500;cursor:pointer;color:var(--text2);transition:all .12s;user-select:none}
.chip:hover{border-color:#0D7A5F;color:#0D7A5F}
.chip.selected{background:var(--green-bg);border-color:#0D7A5F;color:#0D7A5F}
.chip-remove{font-size:15px;color:var(--text3);line-height:1;cursor:pointer;padding:0 2px}
.chip-remove:hover{color:var(--red)}

::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
</style>
</head>
<body>

<div class="shell">
  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="logo">split<span>wise</span></div>
    <button class="nav-btn active" onclick="showView('overview',this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Overview
    </button>
    <button class="nav-btn" onclick="showView('expenses',this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      Expenses
    </button>
    <button class="nav-btn" onclick="showView('splits',this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Splits
    </button>
    <button class="nav-btn" onclick="showView('insights',this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Insights
    </button>
    <button class="nav-btn" onclick="showView('budget',this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Budget limits
    </button>
    <button class="nav-btn" onclick="showView('settings',this)">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
      Settings
    </button>
    <div class="sidebar-footer">
      <div class="month-label" id="sidebar-month"></div>
      <div id="sync-status" style="padding:.4rem .75rem;font-size:12px;color:var(--text3);display:flex;align-items:center;gap:6px"></div>
      <button id="sign-out-btn" class="nav-btn" style="display:none;color:var(--red);font-size:13px" onclick="signOut()">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </button>
    </div>
  </nav>

  <!-- Main content -->
  <main class="main">

    <!-- OVERVIEW -->
    <div id="view-overview" class="view active">
      <div class="page-header">
        <h1 class="page-title">Overview</h1>
        <div class="month-switcher">
          <button onclick="prevMonth()">‹</button>
          <span class="month-display" id="month-display"></span>
          <button onclick="nextMonth()">›</button>
        </div>
      </div>
      <div class="metrics" id="metrics"></div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">Recent expenses</span>
          <button class="btn" onclick="openAddModal()">+ Add expense</button>
        </div>
        <div class="card-body" id="recent-expenses"></div>
      </div>
    </div>

    <!-- EXPENSES -->
    <div id="view-expenses" class="view">
      <div class="page-header">
        <h1 class="page-title">All expenses</h1>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <div class="month-switcher">
            <button onclick="prevMonth()">‹</button>
            <span class="month-display2" id="month-display2"></span>
            <button onclick="nextMonth()">›</button>
          </div>
          <select id="filter-cat" style="border:1px solid var(--border);border-radius:var(--radius-sm);padding:.45rem .6rem;font-size:13px;background:var(--surface);color:var(--text);outline:none;cursor:pointer" onchange="renderAll()">
            <option value="">All categories</option>
            <option value="food">Food</option>
            <option value="transport">Transport</option>
            <option value="entertainment">Entertainment</option>
            <option value="utilities">Utilities</option>
            <option value="shopping">Shopping</option>
            <option value="health">Health</option>
            <option value="other">Other</option>
          </select>
          <button class="btn btn-primary" onclick="openAddModal()">+ Add expense</button>
        </div>
      </div>
      <div class="card">
        <div class="card-body" id="all-expenses"></div>
      </div>
    </div>

    <!-- SPLITS -->
    <div id="view-splits" class="view">
      <div class="page-header">
        <h1 class="page-title">Splits</h1>
        <button class="btn btn-primary" onclick="openAddModal()">+ Add expense</button>
      </div>
      <div id="splits-summary" class="metrics"></div>
      <div class="splits-grid" id="splits-list"></div>
    </div>

    <!-- INSIGHTS -->
    <div id="view-insights" class="view">
      <div class="page-header">
        <h1 class="page-title">Insights</h1>
        <div class="month-switcher">
          <button onclick="prevMonth()">‹</button>
          <span class="month-display" id="month-display3"></span>
          <button onclick="nextMonth()">›</button>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Spending by category</span></div>
        <div style="padding:1.25rem" id="cat-chart"></div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Month over month</span></div>
        <div style="padding:1.25rem"><div class="mom-grid" id="mom-grid"></div></div>
      </div>
    </div>

    <!-- BUDGET -->
    <div id="view-budget" class="view">
      <div class="page-header">
        <h1 class="page-title">Budget limits</h1>
        <div class="month-switcher">
          <button onclick="prevMonth()">‹</button>
          <span class="month-display" id="month-display4"></span>
          <button onclick="nextMonth()">›</button>
        </div>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Category limits</span></div>
        <div style="padding:1.25rem" id="budget-bars"></div>
      </div>
    </div>

    <!-- SETTINGS -->
    <div id="view-settings" class="view">
      <div class="page-header"><h1 class="page-title">Settings</h1></div>
      <div class="settings-section">
        <div class="settings-row">
          <div>
            <div class="settings-label">Currency symbol</div>
            <div class="settings-desc">Shown next to all amounts</div>
          </div>
          <div class="settings-control"><input type="text" id="set-currency" maxlength="3" onchange="saveSetting('currency',this.value);renderAll()"></div>
        </div>
        <div class="settings-row">
          <div>
            <div class="settings-label">Monthly budget</div>
            <div class="settings-desc">Your overall monthly spending target</div>
          </div>
          <div class="settings-control"><input type="number" id="set-budget" min="0" onchange="saveSetting('monthlyBudget',parseFloat(this.value)||0);renderAll()"></div>
        </div>
        <div class="settings-row">
          <div>
            <div class="settings-label">Category limits</div>
            <div class="settings-desc">Set per-category monthly limits in the Budget limits tab</div>
          </div>
          <div><button class="btn" onclick="showView('budget',null)">Go to budget →</button></div>
        </div>
        <div class="settings-row" style="flex-direction:column;align-items:flex-start;gap:.75rem">
          <div>
            <div class="settings-label">Friends / roommates</div>
            <div class="settings-desc">Saved names appear as tap-to-select chips when adding expenses</div>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:6px;width:100%" id="settings-friend-chips"></div>
          <div style="display:flex;gap:8px;width:100%">
            <input type="text" id="new-friend-name" placeholder="Add a name…" maxlength="30" style="flex:1;border:1px solid var(--border);border-radius:var(--radius-sm);padding:.45rem .7rem;font-size:14px;font-family:'Inter',sans-serif;background:var(--surface);color:var(--text);outline:none" onkeydown="if(event.key==='Enter')addFriend()">
            <button class="btn btn-primary" onclick="addFriend()">Add</button>
          </div>
        </div>
        <div class="settings-row">
          <div>
            <div class="settings-label">Export data</div>
            <div class="settings-desc">Download all expenses as CSV</div>
          </div>
          <div><button class="btn" onclick="exportCSV()">Export CSV</button></div>
        </div>
        <div class="settings-row">
          <div>
            <div class="settings-label">Clear all data</div>
            <div class="settings-desc">Remove all expenses and reset settings</div>
          </div>

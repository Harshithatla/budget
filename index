<div class="toast" id="toast"></div>

<script>
// ── Google OAuth config ────────────────────────────────────────────────────
// TO USE THIS APP:
// 1. Go to https://console.cloud.google.com/
// 2. Create a project → Enable "Google Drive API"
// 3. Create OAuth credentials (Web app) → add your file's origin to allowed origins
// 4. Paste your Client ID below
const GOOGLE_CLIENT_ID = 'YOUR_GOOGLE_CLIENT_ID_HERE';
const DRIVE_SCOPES = 'https://www.googleapis.com/auth/drive.appdata';
const DATA_FILENAME = 'splitwise-budget.json';

let accessToken = null;
let driveFileId = null;
let syncTimeout = null;

// ── State ──────────────────────────────────────────────────────────────────
const STORAGE_KEY = 'splitwise_data';
const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const CATS = {food:'🍽',transport:'🚗',entertainment:'🎬',utilities:'⚡',shopping:'🛍',health:'💊',other:'📦'};
const CAT_NAMES = {food:'Food & dining',transport:'Transport',entertainment:'Entertainment',utilities:'Utilities',shopping:'Shopping',health:'Health',other:'Other'};
const CAT_COLORS = {food:'#0D7A5F',transport:'#1A5FA0',entertainment:'#C2456A',utilities:'#C07C1A',shopping:'#5B46B8',health:'#B53030',other:'#6B6A65'};
const CAT_BG = {food:'#E8F5F0',transport:'#EAF1FB',entertainment:'#FBEAF0',utilities:'#FEF3E2',shopping:'#EFEDFC',health:'#FDEAEA',other:'#F0EFE9'};

let now = new Date();
let currentYear = now.getFullYear();
let currentMonth = now.getMonth();

function defaultData() {
  const y = now.getFullYear(), m = String(now.getMonth()+1).padStart(2,'0');
  const lm = now.getMonth()===0 ? `${y-1}-12` : `${y}-${String(now.getMonth()).padStart(2,'0')}`;
  return {
    settings: { currency:'$', monthlyBudget:2000 },
    friends: [],
    budgetLimits: { food:500, transport:200, entertainment:150, utilities:300, shopping:200, health:100, other:100 },
    expenses: [],
    nextId: 1
  };
}

function loadLocalData() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || defaultData(); }
  catch(e) { return defaultData(); }
}
function saveLocalData() { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

let data = loadLocalData();

// ── Sync status UI ─────────────────────────────────────────────────────────
function setSyncStatus(msg, color) {
  const el = document.getElementById('sync-status');
  if (el) el.innerHTML = `<span style="width:7px;height:7px;border-radius:50%;background:${color||'var(--text3)'};flex-shrink:0"></span>${msg}`;
}

// ── Google Drive sync ──────────────────────────────────────────────────────
async function findOrCreateDriveFile() {
  // Search in appDataFolder
  const search = await fetch(
    `https://www.googleapis.com/drive/v3/files?spaces=appDataFolder&q=name='${DATA_FILENAME}'&fields=files(id,name)`,
    { headers: { Authorization: `Bearer ${accessToken}` } }
  );
  const result = await search.json();
  if (result.files && result.files.length > 0) {
    driveFileId = result.files[0].id;
    return driveFileId;
  }
  // Create new file
  const meta = { name: DATA_FILENAME, parents: ['appDataFolder'] };
  const content = JSON.stringify(defaultData());
  const form = new FormData();
  form.append('metadata', new Blob([JSON.stringify(meta)], { type: 'application/json' }));
  form.append('file', new Blob([content], { type: 'application/json' }));
  const create = await fetch(
    'https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart&fields=id',
    { method: 'POST', headers: { Authorization: `Bearer ${accessToken}` }, body: form }
  );
  const file = await create.json();
  driveFileId = file.id;
  return driveFileId;
}

async function loadFromDrive() {
  if (!accessToken) return;
  setSyncStatus('Syncing…', '#C07C1A');
  try {
    await findOrCreateDriveFile();
    const res = await fetch(
      `https://www.googleapis.com/drive/v3/files/${driveFileId}?alt=media`,
      { headers: { Authorization: `Bearer ${accessToken}` } }
    );
    const remote = await res.json();
    // Merge: use remote as source of truth, but keep local if remote is empty/default
    if (remote && remote.expenses) {
      data = remote;
      saveLocalData();
    }
    setSyncStatus('Synced', '#0D7A5F');
    renderAll();
  } catch(e) {
    setSyncStatus('Sync error', '#B53030');
    console.error('Drive load error', e);
  }
}

async function saveToDrive() {
  if (!accessToken || !driveFileId) { saveLocalData(); return; }
  setSyncStatus('Saving…', '#C07C1A');
  try {
    saveLocalData();
    await fetch(
      `https://www.googleapis.com/upload/drive/v3/files/${driveFileId}?uploadType=media`,
      {
        method: 'PATCH',
        headers: { Authorization: `Bearer ${accessToken}`, 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      }
    );
    setSyncStatus('Synced', '#0D7A5F');
  } catch(e) {
    setSyncStatus('Saved locally', '#C07C1A');
    console.error('Drive save error', e);
  }
}

function saveData() {
  saveLocalData();
  // Debounce Drive saves — wait 1.5s after last change
  clearTimeout(syncTimeout);
  syncTimeout = setTimeout(saveToDrive, 1500);
}

// ── Google Sign-In ─────────────────────────────────────────────────────────
function initGoogleAuth() {
  const signinScreen = document.getElementById('signin-screen');

  if (GOOGLE_CLIENT_ID === 'YOUR_GOOGLE_CLIENT_ID_HERE') {
    // Demo mode — no OAuth configured, run offline with localStorage only
    signinScreen.style.display = 'none';
    setSyncStatus('Local mode (no sync)', '#9E9D98');
    renderAll();
    return;
  }

  signinScreen.style.display = 'flex';

  google.accounts.oauth2.initTokenClient({
    client_id: GOOGLE_CLIENT_ID,
    scope: DRIVE_SCOPES,
    callback: async (response) => {
      if (response.error) { setSyncStatus('Sign-in failed', '#B53030'); return; }
      accessToken = response.access_token;
      signinScreen.style.display = 'none';
      document.getElementById('sign-out-btn').style.display = 'flex';
      await loadFromDrive();
    }
  }).requestAccessToken();

  google.accounts.id.initialize({
    client_id: GOOGLE_CLIENT_ID,
    callback: () => {}
  });

  google.accounts.id.renderButton(
    document.getElementById('google-signin-btn'),
    { theme: 'outline', size: 'large', text: 'signin_with', shape: 'rectangular', width: 280 }
  );
}

function signOut() {
  if (accessToken) google.accounts.oauth2.revoke(accessToken, () => {});
  accessToken = null;
  driveFileId = null;
  document.getElementById('sign-out-btn').style.display = 'none';
  setSyncStatus('', '');
  document.getElementById('signin-screen').style.display = 'flex';
}

// ── Helpers ────────────────────────────────────────────────────────────────
function cur() { return data.settings.currency || '$'; }
function fmt(n) { return cur() + Number(n).toFixed(2); }
function monthKey(y,m) { return `${y}-${String(m+1).padStart(2,'0')}`; }
function currentKey() { return monthKey(currentYear, currentMonth); }
function expensesForMonth(y,m) {
  const k = monthKey(y,m);
  return data.expenses.filter(e => e.date && e.date.startsWith(k));
}
function totalSpend(exps) { return exps.reduce((s,e) => s+e.amount, 0); }
function owedFrom(e) {
  if (!e.splits.length || e.settled) return 0;
  return (e.amount / (e.splits.length + 1)) * e.splits.length;
}
function totalOwed(exps) { return exps.reduce((s,e) => s+owedFrom(e), 0); }
function initials(name) { return name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2); }
function saveSetting(key, val) { data.settings[key] = val; saveData(); }

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

// ── Navigation ─────────────────────────────────────────────────────────────
function showView(name, btn) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  document.querySelectorAll('.nav-btn, .mob-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  renderAll();
}

function prevMonth() {
  currentMonth--;
  if (currentMonth < 0) { currentMonth = 11; currentYear--; }
  renderAll();
}
function nextMonth() {
  currentMonth++;
  if (currentMonth > 11) { currentMonth = 0; currentYear++; }
  renderAll();
}

// ── Render ─────────────────────────────────────────────────────────────────
function renderAll() {
  const exps = expensesForMonth(currentYear, currentMonth);
  const mLabel = MONTHS[currentMonth] + ' ' + currentYear;
  document.querySelectorAll('#month-display,#month-display2,#month-display3,#month-display4').forEach(el => { if(el) el.textContent = mLabel; });
  const sideMonth = document.getElementById('sidebar-month');
  if (sideMonth) sideMonth.textContent = mLabel;
  renderMetrics(exps);
  renderRecentExpenses(exps);
  renderAllExpenses(exps);
  renderSplits();
  renderInsights(exps);
  renderBudget(exps);
  renderSettings();
}

function expenseRowHTML(e) {
  const owed = owedFrom(e);
  const splitText = e.splits.length ? `Split with ${e.splits.join(', ')}` : 'Personal';
  return `<div class="expense-row" onclick="editExpense(${e.id})">
    <div class="cat-dot" style="background:${CAT_BG[e.cat]||CAT_BG.other}">${CATS[e.cat]||CATS.other}</div>
    <div class="exp-info">
      <div class="exp-name">${e.desc}${e.splits.length ? `<span class="pill ${e.settled?'pill-settled':'pill-pending'}">${e.settled?'settled':'pending'}</span>` : ''}</div>
      <div class="exp-meta">${e.date} · ${CAT_NAMES[e.cat]||'Other'} · ${splitText}${e.notes?` · ${e.notes}`:''}</div>
    </div>
    <div class="exp-right">
      <div class="exp-amount">${fmt(e.amount)}</div>
      ${owed>0 ? `<div class="exp-owed">+${fmt(owed)} back</div>` : ''}
    </div>
  </div>`;
}

function renderMetrics(exps) {
  const spend = totalSpend(exps);
  const owed = totalOwed(exps);
  const budget = data.settings.monthlyBudget || 0;
  const pct = budget ? Math.min(Math.round(spend/budget*100), 100) : null;
  const el = document.getElementById('metrics');
  if (!el) return;
  el.innerHTML = `
    <div class="metric"><div class="metric-label">Total spending</div><div class="metric-value">${fmt(spend)}</div>${budget?`<div class="metric-sub">${pct}% of ${fmt(budget)} budget</div>`:'<div class="metric-sub">&nbsp;</div>'}</div>
    <div class="metric"><div class="metric-label">Owed to you</div><div class="metric-value c-green">${fmt(owed)}</div><div class="metric-sub">from friends</div></div>
    <div class="metric"><div class="metric-label">Out of pocket</div><div class="metric-value c-amber">${fmt(spend - owed)}</div><div class="metric-sub">your actual cost</div></div>
    <div class="metric"><div class="metric-label">Expenses logged</div><div class="metric-value">${exps.length}</div><div class="metric-sub">this month</div></div>
  `;
}

function renderRecentExpenses(exps) {
  const el = document.getElementById('recent-expenses');
  if (!el) return;
  const sorted = [...exps].sort((a,b) => b.date.localeCompare(a.date)).slice(0,5);
  el.innerHTML = sorted.length ? sorted.map(expenseRowHTML).join('') : '<div class="empty-state">No expenses this month<p>Hit + Add expense to get started</p></div>';
}

function renderAllExpenses(exps) {
  const el = document.getElementById('all-expenses');
  if (!el) return;
  const cat = document.getElementById('filter-cat')?.value || '';
  const filtered = [...exps].filter(e => !cat || e.cat===cat).sort((a,b) => b.date.localeCompare(a.date));
  el.innerHTML = filtered.length ? filtered.map(expenseRowHTML).join('') : '<div class="empty-state">No expenses found<p>Try changing the filter or add a new expense</p></div>';
}

function renderSplits() {
  const pending = data.expenses.filter(e => e.splits.length && !e.settled);
  const byPerson = {};
  pending.forEach(e => {
    const per = e.amount / (e.splits.length + 1);
    e.splits.forEach(p => {
      if (!byPerson[p]) byPerson[p] = { total:0, items:[], ids:[] };
      byPerson[p].total += per;
      byPerson[p].items.push(e.desc);
      byPerson[p].ids.push(e.id);
    });
  });
  const totalPendingOwed = Object.values(byPerson).reduce((s,v) => s+v.total, 0);
  const summaryEl = document.getElementById('splits-summary');
  if (summaryEl) {
    summaryEl.innerHTML = `
      <div class="metric"><div class="metric-label">Total pending</div><div class="metric-value c-amber">${fmt(totalPendingOwed)}</div><div class="metric-sub">across all friends</div></div>
      <div class="metric"><div class="metric-label">Friends with balance</div><div class="metric-value">${Object.keys(byPerson).length}</div><div class="metric-sub">people owe you</div></div>
      <div class="metric"><div class="metric-label">Pending expenses</div><div class="metric-value">${pending.length}</div><div class="metric-sub">not yet settled</div></div>
    `;
  }
  const el = document.getElementById('splits-list');
  if (!el) return;
  if (!Object.keys(byPerson).length) {
    el.innerHTML = '<div class="no-splits"><div style="font-size:2rem;margin-bottom:.5rem">🎉</div><div style="font-size:15px;font-weight:500;color:var(--text)">All settled up!</div><p style="margin-top:.25rem;font-size:13px">No pending splits right now</p></div>';
    return;
  }
  el.innerHTML = Object.entries(byPerson).sort((a,b) => b[1].total - a[1].total).map(([p,d]) => `
    <div class="split-card">
      <div class="split-header">
        <div class="split-person"><div class="avatar">${initials(p)}</div><div><div class="split-name">${p}</div><div style="font-size:12px;color:var(--text3)">${d.ids.length} expense${d.ids.length>1?'s':''}</div></div></div>
        <div class="split-amount">${fmt(d.total)}</div>
      </div>
      <div class="split-items">${d.items.join(' · ')}</div>
      <button class="btn" style="margin-top:.5rem;font-size:12px" onclick="settlePerson('${p}')">Mark settled ✓</button>
    </div>`).join('');
}

function renderInsights(exps) {
  const byCat = {};
  exps.forEach(e => { byCat[e.cat] = (byCat[e.cat]||0) + e.amount; });
  const maxVal = Math.max(...Object.values(byCat), 1);
  const catEl = document.getElementById('cat-chart');
  if (catEl) {
    catEl.innerHTML = Object.entries(byCat).sort((a,b) => b[1]-a[1]).map(([c,v]) => `
      <div class="chart-row">
        <div class="chart-lbl">${CATS[c]} ${CAT_NAMES[c]||c}</div>
        <div class="chart-track">
          <div class="chart-fill" style="width:${Math.round(v/maxVal*100)}%;background:${CAT_COLORS[c]||'#888'}">
            <span class="chart-val" style="color:#fff">${fmt(v)}</span>
          </div>
        </div>
      </div>`).join('') || '<p style="color:var(--text3);font-size:13px">No expenses this month</p>';
  }
  const momEl = document.getElementById('mom-grid');
  if (momEl) {
    let rows = '';
    for (let i=5; i>=0; i--) {
      let m = currentMonth - i, y = currentYear;
      if (m < 0) { m += 12; y--; }
      const e = expensesForMonth(y,m);
      const isCurrent = (m === currentMonth && y === currentYear);
      rows += `<div class="mom-card${isCurrent?' mom-current':''}">
        <div class="mom-month">${MONTHS[m].slice(0,3)} ${y}</div>
        <div class="mom-val">${fmt(totalSpend(e))}</div>
      </div>`;
    }
    momEl.innerHTML = rows;
  }
}

function renderBudget(exps) {
  const el = document.getElementById('budget-bars');
  if (!el) return;
  const byCat = {};
  exps.forEach(e => { byCat[e.cat] = (byCat[e.cat]||0) + e.amount; });
  el.innerHTML = Object.entries(CAT_NAMES).map(([c,name]) => {
    const spent = byCat[c] || 0;
    const limit = data.budgetLimits[c] || 0;
    const pct = limit ? Math.min(Math.round(spent/limit*100), 100) : 0;
    const over = limit && spent > limit;
    const color = over ? '#B53030' : pct > 75 ? '#C07C1A' : '#0D7A5F';
    return `<div class="budget-row">
      <div class="budget-meta">
        <span class="budget-name">${CATS[c]} ${name}</span>
        <span class="budget-nums">
          ${fmt(spent)} /
          <input type="number" value="${limit||''}" placeholder="no limit" min="0"
            style="width:80px;border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-family:'DM Mono',monospace;font-size:12px;background:var(--surface);color:var(--text);outline:none;text-align:right"
            onchange="setBudgetLimit('${c}',parseFloat(this.value)||0)">
          ${limit ? `<span style="color:${over?'var(--red)':'var(--text3)'}">${over?'⚠ over':pct+'%'}</span>` : ''}
        </span>
      </div>
      ${limit ? `<div class="budget-track"><div class="budget-fill" style="width:${pct}%;background:${color}"></div></div>` : '<div class="budget-track"><div style="height:100%;background:var(--border);border-radius:20px;width:100%;opacity:.4"></div></div>'}
    </div>`;
  }).join('');
}

function renderSettings() {
  const ci = document.getElementById('set-currency');
  const bi = document.getElementById('set-budget');
  if (ci) ci.value = data.settings.currency || '$';
  if (bi) bi.value = data.settings.monthlyBudget || '';
  renderSettingsFriends();
}

function setBudgetLimit(cat, val) {
  data.budgetLimits[cat] = val;
  saveData();
  renderAll();
}

// ── Friends / chips ────────────────────────────────────────────────────────
let selectedSplits = [];

function renderModalChips() {
  const friends = data.friends || [];
  const el = document.getElementById('friend-chips');
  if (!el) return;
  if (!friends.length) {
    el.innerHTML = '<span style="font-size:13px;color:var(--text3)">No friends added yet — go to Settings to add some</span>';
    return;
  }
  el.innerHTML = friends.map(f => `
    <div class="chip ${selectedSplits.includes(f)?'selected':''}" onclick="toggleChip('${f}')">${f}</div>
  `).join('');
}

function toggleChip(name) {
  if (selectedSplits.includes(name)) {
    selectedSplits = selectedSplits.filter(n => n !== name);
  } else {
    selectedSplits.push(name);
  }
  renderModalChips();
}

function renderSettingsFriends() {
  const el = document.getElementById('settings-friend-chips');
  if (!el) return;
  const friends = data.friends || [];
  if (!friends.length) {
    el.innerHTML = '<span style="font-size:13px;color:var(--text3)">No friends added yet</span>';
    return;
  }
  el.innerHTML = friends.map(f => `
    <div class="chip" style="cursor:default">${f}<span class="chip-remove" onclick="removeFriend('${f}')" title="Remove">×</span></div>
  `).join('');
}

function addFriend() {
  const input = document.getElementById('new-friend-name');
  const name = input.value.trim();
  if (!name) return;
  if (!data.friends) data.friends = [];
  if (data.friends.includes(name)) { showToast('Already in your list'); return; }
  data.friends.push(name);
  saveData();
  input.value = '';
  renderSettingsFriends();
  showToast(`${name} added`);
}

function removeFriend(name) {
  data.friends = (data.friends || []).filter(f => f !== name);
  saveData();
  renderSettingsFriends();
  showToast(`${name} removed`);
}

// ── Modal ──────────────────────────────────────────────────────────────────
function openAddModal() {
  document.getElementById('modal-add-title').textContent = 'Add expense';
  document.getElementById('edit-id').value = '';
  document.getElementById('f-desc').value = '';
  document.getElementById('f-amount').value = '';
  document.getElementById('f-date').value = new Date().toISOString().slice(0,10);
  document.getElementById('f-cat').value = 'food';
  document.getElementById('f-notes').value = '';
  selectedSplits = [];
  renderModalChips();
  document.getElementById('del-btn').style.display = 'none';
  document.getElementById('modal-add').classList.add('open');
}

function editExpense(id) {
  const e = data.expenses.find(x => x.id === id);
  if (!e) return;
  document.getElementById('modal-add-title').textContent = 'Edit expense';
  document.getElementById('edit-id').value = id;
  document.getElementById('f-desc').value = e.desc;
  document.getElementById('f-amount').value = e.amount;
  document.getElementById('f-date').value = e.date;
  document.getElementById('f-cat').value = e.cat;
  document.getElementById('f-notes').value = e.notes || '';
  selectedSplits = [...(e.splits || [])];
  renderModalChips();
  document.getElementById('del-btn').style.display = 'inline-flex';
  document.getElementById('modal-add').classList.add('open');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

function saveExpense() {
  const desc = document.getElementById('f-desc').value.trim();
  const amount = parseFloat(document.getElementById('f-amount').value);
  const date = document.getElementById('f-date').value;
  const cat = document.getElementById('f-cat').value;
  const notes = document.getElementById('f-notes').value.trim();
  if (!desc || isNaN(amount) || amount <= 0 || !date) { showToast('Please fill in all required fields'); return; }
  const splits = [...selectedSplits];
  const editId = parseInt(document.getElementById('edit-id').value);
  if (editId) {
    const idx = data.expenses.findIndex(e => e.id === editId);
    if (idx !== -1) data.expenses[idx] = { ...data.expenses[idx], desc, amount, date, cat, splits, notes };
    showToast('Expense updated');
  } else {
    data.expenses.push({ id: data.nextId++, desc, amount, date, cat, splits, settled: false, notes });
    showToast('Expense added');
  }
  saveData();
  closeModal('modal-add');
  renderAll();
}

function deleteExpense() {
  const id = parseInt(document.getElementById('edit-id').value);
  if (!id) return;
  if (!confirm('Delete this expense?')) return;
  data.expenses = data.expenses.filter(e => e.id !== id);
  saveData();
  closeModal('modal-add');
  renderAll();
  showToast('Expense deleted');
}

function settlePerson(person) {
  data.expenses.forEach(e => { if (e.splits.includes(person)) e.settled = true; });
  saveData();
  renderAll();
  showToast(`${person} marked as settled`);
}

// ── Export / Reset ─────────────────────────────────────────────────────────
function exportCSV() {
  const rows = [['Date','Description','Category','Amount','Split with','Settled','Notes']];
  data.expenses.sort((a,b) => b.date.localeCompare(a.date)).forEach(e => {
    rows.push([e.date, e.desc, CAT_NAMES[e.cat]||e.cat, e.amount.toFixed(2), e.splits.join(';'), e.settled?'Yes':'No', e.notes||'']);
  });
  const csv = rows.map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download = 'expenses.csv';
  a.click();
  showToast('CSV exported');
}

function clearAll() {
  if (!confirm('This will delete all your data. Are you sure?')) return;
  localStorage.removeItem(STORAGE_KEY);
  data = defaultData();
  saveData();
  renderAll();
  showToast('All data cleared');
}

// Close modal on backdrop click
document.getElementById('modal-add').addEventListener('click', function(e) {
  if (e.target === this) closeModal('modal-add');
});

// ── Init ───────────────────────────────────────────────────────────────────
// Run locally first, then init Google auth once script loads
renderAll();
window.addEventListener('load', () => {
  if (typeof google !== 'undefined') {
    initGoogleAuth();
  } else {
    // Google script not loaded (offline), run in local mode
    setSyncStatus('Local mode (no sync)', '#9E9D98');
  }
});
</script>
